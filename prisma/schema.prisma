generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USUARIOS & AUTH
// ============================================

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  phone        String        @default("")
  birthDate    DateTime?
  passwordHash String?
  googleId     String?       @unique
  role         Role          @default(CUSTOMER)
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum Role {
  CUSTOMER
  HOSTES
  ADMIN
}

// ============================================
// MENÚ
// ============================================

model MenuCategory {
  id        String   @id @default(cuid())
  name      String
  position  Int?
  imageUrl  String?  
  dishes    Dish[]
  createdAt DateTime @default(now())
}

model Dish {
  id               String            @id @default(cuid())
  name             String
  description      String?
  price            Float
  imageUrl         String?
  available        Boolean           @default(true)
  position         Int?
  categoryId       String
  category         MenuCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  reservationItems ReservationItem[] // ← platillos pre-ordenados que usan este dish
  createdAt        DateTime          @default(now())
}

// ============================================
// SECCIONES Y MESAS
// ============================================

model Section {
  id          String   @id @default(cuid())
  name        String   @unique // "Terraza", "Planta Alta", "Salón", "Privado"
  description String?
  isActive    Boolean  @default(true)
  tables      Table[]
  createdAt   DateTime @default(now())
}

model Table {
  id                 String        @id @default(cuid())
  number             Int           // número visible: 1, 2, 3...
  capacity           Int           // máximo de personas
  sectionId          String
  section            Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  isActive           Boolean       @default(true)
  reservations       Reservation[] @relation("PrimaryTable")
  linkedReservations Reservation[] @relation("LinkedTable")
  thirdReservations  Reservation[] @relation("ThirdTable")
  fourthReservations Reservation[] @relation("FourthTable")
  createdAt          DateTime      @default(now())
  block              TableBlock?

  @@unique([number, sectionId])
  @@index([sectionId])
}

model TableBlock {
  id        String   @id @default(cuid())
  tableId   String   @unique
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  note      String?
  createdAt DateTime @default(now())
}

// ============================================
// RESERVACIONES
// ============================================

model Reservation {
  id                String            @id @default(cuid())

  // ── Cuenta que hizo la reserva ─────────
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Titular de la reserva ──────────────
  // Independiente del perfil del usuario,
  // por si reserva a nombre de otra persona.
  guestName         String
  guestPhone        String

  // ── Mesa asignada ──────────────────────
  tableId           String?           // mesa principal (o única)
  table             Table?            @relation("PrimaryTable", fields: [tableId], references: [id], onDelete: SetNull)
  linkedTableId     String?           // segunda mesa cuando se combinan dos
  linkedTable       Table?            @relation("LinkedTable", fields: [linkedTableId], references: [id], onDelete: SetNull)
  thirdTableId      String?           // tercera mesa cuando se combinan tres
  thirdTable        Table?            @relation("ThirdTable", fields: [thirdTableId], references: [id], onDelete: SetNull)
  fourthTableId     String?           // cuarta mesa cuando se combinan cuatro
  fourthTable       Table?            @relation("FourthTable", fields: [fourthTableId], references: [id], onDelete: SetNull)

  // ── Detalles del turno ─────────────────
  date              DateTime          // fecha + hora exacta
  duration          Int               @default(90)  // minutos que ocupa la mesa
  guests            Int               // número de comensales
  isLargeGroup      Boolean           @default(false) // >15 personas: reserva área completa por día

  // ── Preferencias del cliente ───────────
  sectionPreference String?           // "Terraza" | "Planta Alta" | "Salón" (no garantizada)
  occasion          String?           // cumpleaños, aniversario, cena de negocios...
  notes             String?           // peticiones especiales

  // ── Pre-orden de platillos ─────────────
  wantsPreOrder     Boolean           @default(false) // ¿quiere agregar platillos?
  preOrderLocked    Boolean           @default(false) // true después de completar el pago

  // ── Pago ───────────────────────────────
  paymentStatus     PaymentStatus     @default(UNPAID)
  paymentIntentId   String?           // ID externo (MercadoPago preferenceId)
  amountPaid        Decimal?          @db.Decimal(10, 2)
  requiresPayment   Boolean           @default(false) // fecha especial con cobro
  creditUsed        Float             @default(0)     // crédito aplicado a esta reserva
  expiresAt         DateTime?         // expira el apartado si no se paga (PENDING_PAYMENT)
  payment           Payment?          @relation("ReservationPayment")

  // ── Check-in con QR ────────────────────
  // El QR contiene la URL: /checkin/[qrToken]
  // El staff abre esa URL y confirma la llegada.
  qrToken           String            @unique @default(cuid())
  checkedInAt       DateTime?         // cuándo llegó el cliente
  checkedInBy       String?           // userId del staff que escaneó

  // ── Estado y ciclo de vida ─────────────
  status            ReservationStatus @default(PENDING)
  confirmedAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?

  // ── Platillos pre-ordenados ────────────
  items             ReservationItem[]

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([date])
  @@index([status])
  @@index([userId])
  @@index([tableId])
  @@index([qrToken])
}

// ============================================
// PRE-ORDEN DE PLATILLOS
// Tabla puente entre Reservation y Dish.
// Se crea DESPUÉS de que la reserva existe,
// solo si wantsPreOrder = true.
// ============================================

model ReservationItem {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  dishId        String
  dish          Dish        @relation(fields: [dishId], references: [id])
  quantity      Int         @default(1)
  notes         String?     // ej: "sin cilantro", "término medio"
  unitPrice     Float       // precio del platillo al momento de reservar

  createdAt     DateTime    @default(now())

  @@index([reservationId])
  @@index([dishId])
}

// ============================================
// ENUMS
// ============================================

enum ReservationStatus {
  PENDING_PAYMENT // esperando pago MP en fechas especiales (con expiresAt)
  PENDING         // recién creada, esperando confirmación
  CONFIRMED       // reserva confirmada
  IN_PROGRESS     // cliente está en el restaurante (EN CURSO)
  DELAYED         // cliente avisó retraso (RETRASO)
  CANCELLED       // cancelada por cliente o admin
  COMPLETED       // cliente asistió (check-in realizado)
  NO_SHOW         // no se presentó
}

enum PaymentStatus {
  UNPAID      // no ha pagado
  PAID        // pago completado
  REFUNDED    // reembolso realizado
  PARTIAL     // pagó el depósito pero no los platillos
}

// ============================================
// FECHAS ESPECIALES (con cobro anticipado)
// ============================================

model SpecialDate {
  id        String   @id @default(cuid())
  month     Int      // 1-12
  day       Int      // 1-31
  label     String   // "Día de las Madres", "San Valentín"...
  amount    Float    @default(500) // monto a cobrar por reserva
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, day])
}

// ============================================
// PAGOS (MercadoPago)
// ============================================

model Payment {
  id              String       @id @default(cuid())
  mpPaymentId     String?      @unique // ID del pago en MP (después del cobro)
  mpPreferenceId  String?      @unique // ID de la preferencia (antes del cobro)
  amount          Float
  status          String       // "pending" | "approved" | "rejected" | "cancelled"
  customerEmail   String
  customerName    String
  customerPhone   String
  reservationId   String?      @unique
  reservation     Reservation? @relation("ReservationPayment", fields: [reservationId], references: [id], onDelete: SetNull)
  rawData         Json?        // respuesta completa MP para debugging
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([customerEmail])
  @@index([customerPhone])
  @@index([status])
}

// ============================================
// CRÉDITOS (por cancelación de reservas pagadas)
// ============================================

model Credit {
  id                   String    @id @default(cuid())
  customerEmail        String
  customerPhone        String
  amount               Float
  used                 Boolean   @default(false)
  source               String    // "cancelled_reservation"
  originReservationId  String?   // reserva cancelada que originó el crédito
  appliedReservationId String?   // reserva que consumió el crédito
  notes                String?
  createdAt            DateTime  @default(now())
  usedAt               DateTime?

  @@index([customerEmail, used])
  @@index([customerPhone, used])
}
