generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USUARIOS & AUTH
// ============================================

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  phone        String
  birthDate    DateTime?
  passwordHash String
  role         Role          @default(CUSTOMER)
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum Role {
  CUSTOMER
  ADMIN
}

// ============================================
// MENÚ
// ============================================

model MenuCategory {
  id        String   @id @default(cuid())
  name      String
  position  Int?
  dishes    Dish[]
  createdAt DateTime @default(now())
}

model Dish {
  id               String            @id @default(cuid())
  name             String
  description      String?
  price            Float
  imageUrl         String?
  available        Boolean           @default(true)
  position         Int?
  categoryId       String
  category         MenuCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  reservationItems ReservationItem[] // ← platillos pre-ordenados que usan este dish
  createdAt        DateTime          @default(now())
}

// ============================================
// SECCIONES Y MESAS
// ============================================

model Section {
  id          String   @id @default(cuid())
  name        String   @unique // "Terraza", "Planta Alta", "Salón", "Privado"
  description String?
  isActive    Boolean  @default(true)
  tables      Table[]
  createdAt   DateTime @default(now())
}

model Table {
  id                 String        @id @default(cuid())
  number             Int           // número visible: 1, 2, 3...
  capacity           Int           // máximo de personas
  sectionId          String
  section            Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  isActive           Boolean       @default(true)
  reservations       Reservation[] @relation("PrimaryTable")
  linkedReservations Reservation[] @relation("LinkedTable")
  createdAt          DateTime      @default(now())

  @@unique([number, sectionId])
  @@index([sectionId])
}

// ============================================
// RESERVACIONES
// ============================================

model Reservation {
  id                String            @id @default(cuid())

  // ── Cuenta que hizo la reserva ─────────
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Titular de la reserva ──────────────
  // Independiente del perfil del usuario,
  // por si reserva a nombre de otra persona.
  guestName         String
  guestPhone        String

  // ── Mesa asignada ──────────────────────
  tableId           String?           // mesa principal (o única)
  table             Table?            @relation("PrimaryTable", fields: [tableId], references: [id], onDelete: SetNull)
  linkedTableId     String?           // segunda mesa cuando se combinan dos
  linkedTable       Table?            @relation("LinkedTable", fields: [linkedTableId], references: [id], onDelete: SetNull)

  // ── Detalles del turno ─────────────────
  date              DateTime          // fecha + hora exacta
  duration          Int               @default(90)  // minutos que ocupa la mesa
  guests            Int               // número de comensales

  // ── Preferencias del cliente ───────────
  sectionPreference String?           // "Terraza" | "Planta Alta" | "Salón" (no garantizada)
  occasion          String?           // cumpleaños, aniversario, cena de negocios...
  notes             String?           // peticiones especiales

  // ── Pre-orden de platillos ─────────────
  wantsPreOrder     Boolean           @default(false) // ¿quiere agregar platillos?
  preOrderLocked    Boolean           @default(false) // true después de completar el pago

  // ── Pago ───────────────────────────────
  paymentStatus     PaymentStatus     @default(UNPAID)
  paymentIntentId   String?           // ID de Stripe
  amountPaid        Decimal?          @db.Decimal(10, 2)

  // ── Check-in con QR ────────────────────
  // El QR contiene la URL: /checkin/[qrToken]
  // El staff abre esa URL y confirma la llegada.
  qrToken           String            @unique @default(cuid())
  checkedInAt       DateTime?         // cuándo llegó el cliente
  checkedInBy       String?           // userId del staff que escaneó

  // ── Estado y ciclo de vida ─────────────
  status            ReservationStatus @default(PENDING)
  confirmedAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?

  // ── Platillos pre-ordenados ────────────
  items             ReservationItem[]

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([date])
  @@index([status])
  @@index([userId])
  @@index([tableId])
  @@index([qrToken])
}

// ============================================
// PRE-ORDEN DE PLATILLOS
// Tabla puente entre Reservation y Dish.
// Se crea DESPUÉS de que la reserva existe,
// solo si wantsPreOrder = true.
// ============================================

model ReservationItem {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  dishId        String
  dish          Dish        @relation(fields: [dishId], references: [id])
  quantity      Int         @default(1)
  notes         String?     // ej: "sin cilantro", "término medio"
  unitPrice     Float       // precio del platillo al momento de reservar

  createdAt     DateTime    @default(now())

  @@index([reservationId])
  @@index([dishId])
}

// ============================================
// ENUMS
// ============================================

enum ReservationStatus {
  PENDING     // recién creada, esperando confirmación + pago
  CONFIRMED   // pago recibido, reserva confirmada → se genera QR
  CANCELLED   // cancelada por cliente o admin
  COMPLETED   // cliente asistió (check-in realizado)
  NO_SHOW     // no se presentó
}

enum PaymentStatus {
  UNPAID      // no ha pagado
  PAID        // pago completado
  REFUNDED    // reembolso realizado
  PARTIAL     // pagó el depósito pero no los platillos
}
